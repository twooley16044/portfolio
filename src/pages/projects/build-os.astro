---
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout title="Build-OS | Travis Wooley" active="projects">

  <section class="hero">
    <div class="eyebrow">FEATURED PROJECT</div>

    <h1>Build-OS</h1>

    <h2>Unified Industrial Intelligence Platform</h2>

    <p class="hero-text">
      Build-OS is a manufacturing operations platform concept that brings
      production visibility, AI assistance, quality tracking, maintenance,
      inventory, shift documentation, production planning, and management
      reporting into one unified workspace.
    </p>

    <p class="hero-text">
      Rather than functioning as another standalone dashboard or chatbot,
      Build-OS explores what it would look like for AI, operational workflows,
      documentation, and factory-floor data to live inside a single connected
      industrial operating system.
    </p>

    <div class="hero-buttons">
      <a href="#overview" class="button primary">
        Explore Project
      </a>

      <a href="/projects" class="button secondary">
        Back to Projects
      </a>
    </div>
  </section>

  <section class="quick-facts">
    <div class="fact-card">
      <h3>Status</h3>
      <p>Active Development</p>
    </div>

    <div class="fact-card">
      <h3>Purpose</h3>
      <p>Industrial Operations Platform</p>
    </div>

    <div class="fact-card">
      <h3>Primary Technologies</h3>
      <p>React • Firebase • Google AI Studio • Gemini</p>
    </div>

    <div class="fact-card">
      <h3>Focus</h3>
      <p>Manufacturing Workflows & Operational Intelligence</p>
    </div>
  </section>

  <section id="overview">
    <h2>The Problem</h2>

    <div class="card">
      <p>
        Manufacturing teams often work across disconnected spreadsheets,
        paper shift logs, maintenance notes, quality records, inventory trackers,
        and communication threads. Critical information becomes fragmented,
        difficult to retrieve, and hard to act on quickly.
      </p>

      <p>
        This creates a data gap between high-level business systems and
        ground-level factory operations. Supervisors, technicians, managers, and
        engineers all need accurate operational context, but that context is
        rarely available in one place.
      </p>
    </div>
  </section>

  <section>
    <h2>The Solution</h2>

    <div class="card">
      <p>
        Build-OS is designed as a unified industrial intelligence platform:
        a single workspace where operations teams can manage production,
        maintenance, quality, safety, inventory, shift handovers, workforce
        skills, reporting, and AI-assisted decision support.
      </p>

      <p>
        The goal is not to replace operational expertise. The goal is to make
        expertise easier to capture, share, retrieve, and act on by connecting
        daily workflows with structured data and practical AI assistance.
      </p>
    </div>
  </section>

  <section>
    <h2>Core Capabilities</h2>

    <div class="feature-grid">

      <div class="feature-card">
        <div class="emoji">🏭</div>

        <h3>Manufacturing Operations Hub</h3>

        <p>
          Centralizes shift logs, incidents, tasks, maintenance, inventory,
          production planning, quality records, and management reporting.
        </p>
      </div>

      <div class="feature-card">
        <div class="emoji">🤖</div>

        <h3>Embedded AI Assistance</h3>

        <p>
          Uses Gemini-powered assistance for navigation, summarization,
          troubleshooting support, reporting, and operational decision support.
        </p>
      </div>

      <div class="feature-card">
        <div class="emoji">📊</div>

        <h3>Operational Visibility</h3>

        <p>
          Presents key information through dashboards, planning views, reports,
          and searchable operational records.
        </p>
      </div>

      <div class="feature-card">
        <div class="emoji">⚙️</div>

        <h3>Configurable Platform Design</h3>

        <p>
          Explores platform concepts such as role-based access, configurable
          modules, custom forms, terminology control, and admin-level settings.
        </p>
      </div>

    </div>
  </section>

  <section>
    <h2>Product Gallery</h2>

    <p class="gallery-intro">
      Build-OS brings together production visibility, AI assistance, quality
      tracking, maintenance workflows, inventory control, shift documentation,
      and management reporting in one manufacturing operations workspace.
      Click any card to open a larger product walkthrough.
    </p>

    <div class="product-gallery">

      <div class="gallery-feature">
        <img
          src="/images/build-os/Dashboard.png"
          alt="Build-OS dashboard"
        />

        <div>
          <span class="gallery-label">Command Center</span>

          <h3>Mission Control Dashboard</h3>

          <p>
            A centralized overview of production health, open incidents,
            completed tasks, inventory status, and key operational actions.
          </p>
        </div>
      </div>

      <div class="gallery-feature">
        <img
          src="/images/build-os/AIHelp.png"
          alt="Build-OS AI help interface"
        />

        <div>
          <span class="gallery-label">AI Assistance</span>

          <h3>Contextual AI Help</h3>

          <p>
            A natural-language assistant designed to help users navigate the
            system, answer operational questions, and reduce time spent searching
            for information.
          </p>
        </div>
      </div>

      <div class="gallery-feature">
        <img
          src="/images/build-os/ProductionPlanningGnatt.png"
          alt="Build-OS production planning Gantt view"
        />

        <div>
          <span class="gallery-label">Production Planning</span>

          <h3>Interactive Production Scheduling</h3>

          <p>
            A Gantt-style planning view helps visualize production demand across
            product lines, compare schedules, and identify capacity or timing
            conflicts.
          </p>
        </div>
      </div>

      <div class="gallery-feature">
        <img
          src="/images/build-os/QC.png"
          alt="Build-OS quality control reports"
        />

        <div>
          <span class="gallery-label">Quality</span>

          <h3>Quality Control Reports</h3>

          <p>
            Lot-level inspection records, pass/fail status, inspector
            attribution, and searchable reports support traceability and quality
            visibility.
          </p>
        </div>
      </div>

      <div class="gallery-feature">
        <img
          src="/images/build-os/Maintenance.png"
          alt="Build-OS maintenance management"
        />

        <div>
          <span class="gallery-label">Maintenance</span>

          <h3>Maintenance Management</h3>

          <p>
            Work orders, preventive maintenance, asset status, and technical
            issues are grouped into a practical maintenance workflow.
          </p>
        </div>
      </div>

      <div class="gallery-feature">
        <img
          src="/images/build-os/Management.png"
          alt="Build-OS management report"
        />

        <div>
          <span class="gallery-label">Reporting</span>

          <h3>AI-Assisted Management Reports</h3>

          <p>
            Operational activity is summarized into management-ready reporting
            that highlights alerts, production status, safety notes, and action
            items.
          </p>
        </div>
      </div>

    </div>
  </section>

  <section>
    <h2>What I Built</h2>

    <div class="card">
      <p>
        Build-OS is a broad manufacturing operations platform prototype designed
        around the way production teams actually work. The application combines
        modules for shift logging, incident tracking, technical issues,
        maintenance, quality control, inventory, production planning, analytics,
        work instructions, employee skills, timecards, administration, and
        AI-assisted reporting.
      </p>

      <p>
        The project demonstrates my ability to translate real operational pain
        points into a software product concept with coherent information
        architecture, modular workflows, practical AI use cases, and a polished
        user experience.
      </p>
    </div>
  </section>

  <section>
    <h2>Why It Matters</h2>

    <div class="feature-grid">

      <div class="feature-card">
        <div class="emoji">🏭</div>

        <h3>Built for Real Operations</h3>

        <p>
          The modules reflect actual shop-floor and production support workflows:
          handoffs, incidents, maintenance, inventory, quality, planning,
          technical issues, and reporting.
        </p>
      </div>

      <div class="feature-card">
        <div class="emoji">🧩</div>

        <h3>Unified System Design</h3>

        <p>
          Rather than separate tools for every department, Build-OS presents a
          single workspace organized around manufacturing roles and workflows.
        </p>
      </div>

      <div class="feature-card">
        <div class="emoji">🤖</div>

        <h3>Practical AI Integration</h3>

        <p>
          AI is positioned as an operational assistant for navigation, reporting,
          summarization, and decision support — not just a generic chatbot.
        </p>
      </div>

    </div>
  </section>

  <div id="image-modal" class="image-modal">
    <div class="modal-content">
      <button id="modal-close" class="modal-close" aria-label="Close product preview">
        ×
      </button>

      <div class="modal-layout">
        <div class="modal-image-panel">
          <img id="modal-image" src="" alt="" />
        </div>

        <div class="modal-info-panel">
          <span id="modal-label" class="gallery-label"></span>

          <h3 id="modal-title"></h3>

          <p id="modal-description" class="modal-summary"></p>

          <div class="modal-detail">
            <h4>Business Problem</h4>
            <p id="modal-problem"></p>
          </div>

          <div class="modal-detail">
            <h4>Platform Capability</h4>
            <p id="modal-capability"></p>
          </div>

          <div class="modal-detail">
            <h4>My Role</h4>
            <p id="modal-role"></p>
          </div>

          <div class="modal-detail">
            <h4>Concepts Demonstrated</h4>
            <p id="modal-concepts"></p>
          </div>

          <div class="modal-nav">
            <button id="modal-prev" class="modal-nav-btn" type="button">
              ← Previous
            </button>

            <button id="modal-next" class="modal-nav-btn" type="button">
              Next →
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    const galleryCards = Array.from(document.querySelectorAll(".gallery-feature"));

    const modal = document.getElementById("image-modal");
    const modalImage = document.getElementById("modal-image");
    const modalLabel = document.getElementById("modal-label");
    const modalTitle = document.getElementById("modal-title");
    const modalDescription = document.getElementById("modal-description");
    const modalProblem = document.getElementById("modal-problem");
    const modalCapability = document.getElementById("modal-capability");
    const modalRole = document.getElementById("modal-role");
    const modalConcepts = document.getElementById("modal-concepts");
    const modalClose = document.getElementById("modal-close");
    const modalPrev = document.getElementById("modal-prev");
    const modalNext = document.getElementById("modal-next");

    let currentIndex = 0;

    const moduleDetails = {
      "mission control dashboard": {
        problem:
          "Manufacturing leaders often have to jump between spreadsheets, shift notes, inventory trackers, task boards, and incident logs just to understand what is happening in the facility.",
        capability:
          "Build-OS centralizes operational health into a mission-control view covering production, tasks, incidents, inventory, announcements, and key actions.",
        role:
          "I designed the dashboard experience around the way supervisors and operations leaders triage daily work: what is behind, what is at risk, and what needs attention now.",
        concepts:
          "Operations dashboards, KPI design, manufacturing visibility, command-center UX, cross-module system thinking"
      },

      "contextual ai help": {
        problem:
          "AI tools are often separated from the actual workflow, forcing users to leave the system, copy context, and manually interpret what to do next.",
        capability:
          "The AI assistant is positioned as an embedded operational intelligence layer for navigation, summarization, troubleshooting, and decision support.",
        role:
          "I shaped the assistant around practical operations use cases rather than generic chat, focusing on how AI can reduce search time and improve workflow execution.",
        concepts:
          "Gemini AI, prompt design, contextual assistance, knowledge retrieval, AI-assisted operations"
      },

      "interactive production scheduling": {
        problem:
          "Production planning is frequently managed in static spreadsheets, making it difficult to visualize timing, demand, capacity, and scheduling conflicts.",
        capability:
          "The production planning module includes a Gantt-style view for visualizing production runs, demand timing, and planning priorities across product lines or workcells.",
        role:
          "I designed this module to communicate production schedule information visually, making the planning workflow easier to understand than a flat table alone.",
        concepts:
          "Production planning, Gantt scheduling, capacity visibility, manufacturing execution workflows, planning UX"
      },

      "quality control reports": {
        problem:
          "Quality data often lives in paper inspection forms, PDFs, spreadsheets, or disconnected systems, making traceability and review difficult.",
        capability:
          "The QC module organizes lot-level inspection records, pass/fail status, inspector attribution, and searchable reports into a structured quality workflow.",
        role:
          "I designed the quality module around practical QA/QC review patterns: fast lookup, clear status, traceable inspection history, and audit-ready structure.",
        concepts:
          "QMS thinking, traceability, inspection records, quality workflows, audit readiness"
      },

      "maintenance management": {
        problem:
          "Maintenance teams often manage work orders, preventive maintenance, asset notes, and technical issues across disconnected tools or informal communication.",
        capability:
          "Build-OS groups work orders, asset health, preventive maintenance, and technical issues into a practical maintenance and reliability workflow.",
        role:
          "I structured this module around the information maintenance teams need to prioritize work, document issues, and support equipment uptime.",
        concepts:
          "CMMS concepts, work orders, preventive maintenance, asset tracking, reliability workflows"
      },

      "ai-assisted management reports": {
        problem:
          "Managers spend significant time turning raw activity from production, safety, maintenance, quality, and staffing into concise updates for leadership.",
        capability:
          "The management reporting view demonstrates how operational activity can be summarized into decision-ready reports with alerts, highlights, and action items.",
        role:
          "I designed this as an example of AI-assisted reporting: converting scattered operational signals into clear management communication.",
        concepts:
          "Executive reporting, operational summaries, AI-assisted documentation, management dashboards"
      }
    };

    function normalizeTitle(text) {
      return text.trim().toLowerCase();
    }

    function getDetailsForCard(card) {
      const title = card.querySelector("h3")?.textContent || "";
      const key = normalizeTitle(title);

      return moduleDetails[key] || {
        problem:
          "Industrial operations depend on accurate, timely information, but that information is often spread across disconnected tools and manual processes.",
        capability:
          "This module demonstrates how Build-OS can consolidate operational workflows into a unified industrial intelligence platform.",
        role:
          "I designed and built this module as part of the broader Build-OS product concept, focusing on practical manufacturing workflows and usable interface design.",
        concepts:
          "Manufacturing operations, workflow design, UI architecture, systems thinking"
      };
    }

    function openModal(index) {
      currentIndex = index;

      const card = galleryCards[currentIndex];
      const img = card.querySelector("img");
      const label = card.querySelector(".gallery-label");
      const title = card.querySelector("h3");
      const description = card.querySelector("p");
      const details = getDetailsForCard(card);

      modalImage.src = img.src;
      modalImage.alt = img.alt;
      modalLabel.textContent = label.textContent;
      modalTitle.textContent = title.textContent;
      modalDescription.textContent = description.textContent;
      modalProblem.textContent = details.problem;
      modalCapability.textContent = details.capability;
      modalRole.textContent = details.role;
      modalConcepts.textContent = details.concepts;

      modal.classList.add("active");
      document.body.classList.add("modal-open");
    }

    function closeModal() {
      modal.classList.remove("active");
      document.body.classList.remove("modal-open");
    }

    function showPrevious() {
      const newIndex = (currentIndex - 1 + galleryCards.length) % galleryCards.length;
      openModal(newIndex);
    }

    function showNext() {
      const newIndex = (currentIndex + 1) % galleryCards.length;
      openModal(newIndex);
    }

    galleryCards.forEach((card, index) => {
      card.setAttribute("role", "button");
      card.setAttribute("tabindex", "0");

      card.addEventListener("click", () => openModal(index));

      card.addEventListener("keydown", (event) => {
        if (event.key === "Enter" || event.key === " ") {
          event.preventDefault();
          openModal(index);
        }
      });
    });

    modalClose.addEventListener("click", closeModal);
    modalPrev.addEventListener("click", showPrevious);
    modalNext.addEventListener("click", showNext);

    modal.addEventListener("click", (event) => {
      if (event.target === modal) {
        closeModal();
      }
    });

    document.addEventListener("keydown", (event) => {
      if (!modal.classList.contains("active")) return;

      if (event.key === "Escape") closeModal();
      if (event.key === "ArrowLeft") showPrevious();
      if (event.key === "ArrowRight") showNext();
    });
  </script>

</MainLayout>